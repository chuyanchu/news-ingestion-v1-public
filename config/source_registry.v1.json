{
  "schema_version": "1.0",
  "owner": "news-ingestion-v1",
  "timezone": "Asia/Shanghai",
  "crawl_policy": {
    "respect_robots_txt": true,
    "min_interval_seconds_per_source": 30,
    "max_retries": 2,
    "timeout_seconds": 15,
    "store_raw_response": true
  },
  "tiers": {
    "T0": "官方公告、交易所、监管和公司信息披露，权威性最高，速度未必最快。",
    "T1": "主流财经媒体和快讯源，适合捕捉当日热点。",
    "T2": "社区和投资者讨论源，适合补充舆情，但噪声高。",
    "T3": "行业媒体、研报摘要和补充来源，适合扩展覆盖。"
  },
  "sources": [
